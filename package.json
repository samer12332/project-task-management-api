{
    "name": "project-task-management-api",
    "version": "1.0.0",
    "description": "RESTful API for a Project and Task Management System",
    "main": "dist/server.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "seed": "ts-node-dev --transpile-only src/seed.ts"
    },
    "keywords": [
        "nodejs",
        "express",
        "typescript",
        "mongodb",
        "mongoose",
        "jwt"
    ],
    "author": "Samer Yousry",
    "license": "MIT",
    "dependencies": {
        "bcrypt": "^6.0.0",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-validator": "^7.3.2",
        "helmet": "^8.2.0",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.7.1",
        "morgan": "^1.11.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/node": "^26.0.0",
        "ts-node-dev": "^2.0.0",
        "typescript": "^6.0.3"
    }
}
